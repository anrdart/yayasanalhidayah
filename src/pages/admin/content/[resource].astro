---
export const prerender = false;
import AdminLayout from '@/layouts/AdminLayout.astro';
import ResourceList from '@/components/admin/resources/ResourceList';
import { RESOURCES } from '@/components/admin/resources.config';
import { isDisabledRoute } from '@/components/admin/nav.config';

const slug = Astro.params.resource!;
const def = RESOURCES[slug];
if (!def) return Astro.redirect('/admin');
// Feature greyed-out in the sidebar (no public page reads it yet) — block
// direct URL access too.
if (isDisabledRoute(`/admin/content/${slug}`)) return Astro.redirect('/admin');

const { data } = await (Astro.locals.supabase as any)
  .from(def.table)
  .select('*')
  .order('sort_order', { ascending: true });
---
<AdminLayout title={def.labelPlural}>
  <ResourceList client:load resourceSlug={slug} initial={(data ?? []) as Record<string, unknown>[]} />
</AdminLayout>
