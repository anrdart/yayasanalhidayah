---
export const prerender = false;
import AdminLayout from '@/layouts/AdminLayout.astro';
import ResourceForm from '@/components/admin/resources/ResourceForm';
import { RESOURCES } from '@/components/admin/resources.config';

const slug = Astro.params.resource!;
const id = Astro.params.id!;
const def = RESOURCES[slug];
if (!def) return Astro.redirect('/admin');

const { data } = await (Astro.locals.supabase as any)
  .from(def.table)
  .select('*')
  .eq('id', id)
  .maybeSingle();

if (!data) return Astro.redirect(`/admin/content/${slug}`);
---
<AdminLayout title={`Edit ${def.label}`}>
  <ResourceForm client:load resourceSlug={slug} initial={data} />
</AdminLayout>
