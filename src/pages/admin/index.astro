---
export const prerender = false;
import AdminLayout from '@/layouts/AdminLayout.astro';
import DashboardHome from '@/components/admin/DashboardHome';

const supabase = Astro.locals.supabase;

// Recent activity + last heartbeat for the dashboard widgets.
const [{ data: recent }, { data: lastHb }] = await Promise.all([
  supabase.from('activity_log').select('*').order('created_at', { ascending: false }).limit(12),
  supabase.rpc('last_heartbeat'),
]);

// Dashboard metrics. Campaign-centric (the core of the org) + content count.
// programs carries the live donation stats synced from WP, so we aggregate
// raised_amount / donatur_count across all rows here.
const [programsRes, { count: articleCount }] = await Promise.all([
  supabase.from('programs').select('raised_amount, donatur_count'),
  supabase.from('articles').select('*', { count: 'exact', head: true }),
]);

type ProgramStat = { raised_amount: number | null; donatur_count: number | null };
const programs = (programsRes.data ?? []) as ProgramStat[];
const counts: Record<string, number> = {
  programs: programs.length,
  raised: programs.reduce((s, p) => s + (p.raised_amount ?? 0), 0),
  donatur: programs.reduce((s, p) => s + (p.donatur_count ?? 0), 0),
  articles: articleCount ?? 0,
};
---
<AdminLayout title="Dashboard">
  <DashboardHome
    client:load
    recent={recent ?? []}
    lastHeartbeat={typeof lastHb === 'string' ? lastHb : null}
    counts={counts}
  />
</AdminLayout>
