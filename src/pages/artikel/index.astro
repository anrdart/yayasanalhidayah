---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogCard from '../../components/BlogCard.astro';
import { listPublishedArticles } from '@/lib/supabase/queries/articles';

const page = Math.max(1, Number(Astro.url.searchParams.get('page') ?? '1'));
const { articles, totalPages } = await listPublishedArticles(Astro.locals.supabase, { page, perPage: 9 });
---

<Base
  title="Artikel — Yayasan Alhidayah"
  description="Artikel dan kabar terbaru seputar kegiatan Yayasan Alhidayah: wakaf mushaf, kafarat, fidyah, dan bantuan sosial."
>
  <Header base="/" />
  <main id="main-content">
    <section class="section-pad" style="padding-top: 140px;">
      <div class="container">
        <div data-reveal>
          <div class="eyebrow"><span>Blog</span></div>
          <h1 class="display" style="margin-top:16px;">Artikel <em>Terbaru</em></h1>
          <p class="lede" style="max-width: 640px; margin-top: 16px;">
            Kabar dari lapangan, update program, dan refleksi seputar amal dan kebaikan yang kami amanahkan.
          </p>
        </div>
      </div>
    </section>

    <section class="section-pad" style="padding-top:0">
      <div class="container">
        {articles.length === 0 ? (
          <div class="blog-empty" data-reveal>
            <div class="blog-empty__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                <path d="M9 7h7M9 11h7" />
              </svg>
            </div>
            <h2 class="blog-empty__title">Tulisan pertama sedang disiapkan</h2>
            <p class="blog-empty__text">
              Kami sedang menyiapkan kabar dari lapangan, update program, dan refleksi seputar amal.
              Sementara itu, Anda bisa menjelajahi program donasi yang sedang berjalan.
            </p>
            <div class="blog-empty__actions">
              <a href="/program" class="btn btn-primary">Lihat Program Donasi</a>
              <a href="/" class="btn btn-ghost">Kembali ke Beranda</a>
            </div>
          </div>
        ) : (
          <div class="blog-grid">
            {articles.map((a) => (
              <BlogCard
                slug={a.slug}
                title={a.title}
                excerpt={a.excerpt}
                cover_image={a.cover_image}
                published_at={a.published_at}
                reading_time={a.reading_time}
                category={a.category}
              />
            ))}
          </div>
        )}

        {totalPages > 1 && (
          <nav class="blog-pagination" aria-label="Navigasi halaman" data-reveal>
            {page > 1 && (
              <a href={`/artikel?page=${page - 1}`} class="btn btn-ghost">← Sebelumnya</a>
            )}
            <span class="blog-pagination__info">Halaman {page} dari {totalPages}</span>
            {page < totalPages && (
              <a href={`/artikel?page=${page + 1}`} class="btn btn-ghost">Selanjutnya →</a>
            )}
          </nav>
        )}
      </div>
    </section>
  </main>
  <Footer base="/" />
</Base>

<style>
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }
  /* Zero-state: keeps the footer down and reads as intentional, not broken. */
  .blog-empty {
    min-height: 44vh;
    max-width: 520px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 48px 0 24px;
  }
  .blog-empty__icon {
    width: 72px;
    height: 72px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--bg-alt);
    color: var(--brand);
    margin-bottom: 24px;
  }
  .blog-empty__icon svg { width: 32px; height: 32px; }
  .blog-empty__title {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.4vw, 28px);
    font-weight: 600;
    color: var(--ink);
    line-height: 1.2;
    margin: 0 0 12px;
  }
  .blog-empty__text {
    color: var(--ink-2);
    font-size: 15px;
    line-height: 1.6;
    margin: 0 0 28px;
  }
  .blog-empty__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }
  @media (max-width: 480px) {
    .blog-empty__actions { width: 100%; }
    .blog-empty__actions .btn { width: 100%; justify-content: center; }
  }
  .blog-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 56px;
  }
  .blog-pagination__info {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--ink-3);
  }
</style>
